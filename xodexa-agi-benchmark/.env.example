# Xodexa AI Benchmark — environment template. Copy to .env and fill in.
# .env is git-ignored. NEVER commit real secrets.

# --- Database (docker-compose sets DATABASE_URL for the containers) ---
POSTGRES_USER=xodexa
POSTGRES_PASSWORD=change-me
POSTGRES_DB=xodexa
# Local (no docker) dev defaults to SQLite if DATABASE_URL is unset.
# DATABASE_URL=postgresql+psycopg://xodexa:change-me@localhost:5432/xodexa

# --- Queue / worker ---
REDIS_URL=redis://redis:6379/0
# RUN_INLINE=1   # dev only: run benchmark jobs in-process instead of via the worker

# --- Secrets (generate your own; do not reuse these) ---
# KEY_ENCRYPTION_KEY encrypts users' provider API keys at rest (Fernet, urlsafe b64, 32 bytes).
# Generate: python -c "from apps.server.security import generate_fernet_key as g; print(g())"
KEY_ENCRYPTION_KEY=
# SESSION_SECRET signs CSRF tokens + derives the dev fallback key. Use a long random string.
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_TTL_HOURS=168
COOKIE_SECURE=false           # set true in production (HTTPS)

# --- Email verification (privateemail.com) ---
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=info@xodexabenchmark.com
SMTP_PASSWORD=                # set the mailbox password here (never commit it)
MAIL_FROM=info@xodexabenchmark.com
MAIL_FROM_NAME=Xodexa AI Benchmark
# If SMTP_PASSWORD is empty, verification links are printed to the server log (dev mode).

# --- Public URL (used in verification links + redirects) ---
PUBLIC_BASE_URL=http://localhost:8000
# CORS_ORIGINS=https://your-frontend.example   # only if the frontend is hosted separately

# --- Legitimacy / anti-runaway quotas ---
MAX_TASKS_PER_RUN=200
MIN_TASKS_PER_RUN=5
MAX_CONCURRENT_RUNS=1
MAX_RUNS_PER_DAY=10
MAX_TASKS_PER_DAY=1000
VERIFICATION_TTL_HOURS=24

# --- Trust kernel (official self-hosted-runner scoring; optional) ---
# APEX_SERVER_PRIVATE_KEY=
# APEX_SERVER_PUBLIC_KEY=
BENCHMARK_VERSION=1.0.0
