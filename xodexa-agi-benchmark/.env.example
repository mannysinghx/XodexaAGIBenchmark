# Xodexa AGI Benchmark — environment template. Copy to .env and fill in.

# --- Database ---
POSTGRES_USER=apex
POSTGRES_PASSWORD=change-me
POSTGRES_DB=xodexa
DATABASE_URL=postgresql://apex:change-me@db:5432/xodexa

# --- Cache / queue ---
REDIS_URL=redis://redis:6379/0

# --- Object storage (MinIO / S3) ---
S3_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=apexadmin
MINIO_ROOT_PASSWORD=change-me
S3_BUCKET=xodexa-result-bundles

# --- Scoring authority signing key (Ed25519, base64 raw) ---
# Generate: python -c "from xodexa import KeyPair; k=KeyPair.generate(); print('PRIV',k.priv_b64); print('PUB',k.pub_b64)"
# NEVER commit the private key. In production load from OpenBao/Vault, not env.
APEX_SERVER_PRIVATE_KEY=
APEX_SERVER_PUBLIC_KEY=

# --- Auth (Ory/Keycloak) — optional for MVP, JWT fallback otherwise ---
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
JWT_SECRET=change-me

# --- Policy ---
BENCHMARK_VERSION=1.0.0
ALLOWED_RUNNER_VERSIONS=0.1.0,0.1.1
MIN_PLAUSIBLE_MS_PER_TASK=40
